# Database Configuration
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_HOST=mysql-1663326c-kritiyadavcoding-6ab9.a.aivencloud.com
DB_PORT=13918

# Optional SSL settings for Aiven
# Path to downloaded Aiven CA (ca.pem). Example: C:\Users\You\Downloads\aiven-ca.pem
DB_SSL_CA_PATH=
# Whether to require SSL connection (true/false). If blank, inferred from DB_SSL_CA_PATH
DB_SSL_REQUIRE=true
# Whether to reject unauthorized certs (true in production when CA provided)
DB_SSL_REJECT_UNAUTHORIZED=false

# Connection pool (optional)
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (comma-separated for multiple domains)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
